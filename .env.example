# Configurações de Deploy - Elemental Protocol
# Copie este arquivo para .env e preencha com seus dados

# Private Key da carteira de deploy (NUNCA compartilhe ou commit este arquivo)
PRIVATE_KEY=0x...

# URL do RPC da Sepolia (Infura, Alchemy, ou outro provider)
SEPOLIA_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Etherscan API Key (para verificação automática de contratos)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Configurações opcionais
# NETWORK=sepolia
# GAS_LIMIT=3000000
# GAS_PRICE=gwei
